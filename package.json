    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.16.1",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jsdom": "^29.1.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
